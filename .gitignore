# Zephyr build folders
/build/
/build_*/

# Zephyr logs
log*.txt

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Secret keys
**/keys/private/*

# Local Kconfig overrides (real device secrets); see samples/*/CMakeLists.txt
# for the auto-merge-if-present logic.
prj.local.conf

# Python venv
.venv/

# Cache
.cache/

# West deps (fetched via `west update`, not part of this repo)
/mbedtls/
/nrf/
/nrfxlib/
/pcf85063a/
/tools/
/modules/
/bootloader/
/zephyr/
# No trailing slash: pigeon is a symlink to a local checkout, and a
# trailing-slash pattern only matches real directories, not symlinks.
/pigeon

# Pristine reference copy of the original Nordic NIDD sample this workspace
# was bootstrapped from — kept on disk locally, not part of this repo.
/nidd-sample/

# Cortex debugging states
.vscode/.cortex-debug.registers.state.json
